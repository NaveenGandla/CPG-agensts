# ── Azure OpenAI / AI Foundry ────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_TEMPERATURE=0.3

# ── Azure AI Search ─────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=cpg-knowledge-base
AZURE_SEARCH_SEMANTIC_CONFIG=cpg-semantic-config
AZURE_SEARCH_TOP_K=10

# ── Azure Document Intelligence (for template parsing) ──────────
AZURE_DI_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=                          # Optional — omit to use Managed Identity
AZURE_DI_MODEL_ID=prebuilt-layout

# ── Azure Application Insights ──────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
LOG_LEVEL=INFO


# ── Application ─────────────────────────────────────────────────
APP_NAME=cpg-multi-agent
ENVIRONMENT=production
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
