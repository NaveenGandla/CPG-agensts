# ── Authentication Mode ─────────────────────────────────────────
# Set to "key" to use API keys, or "identity" to use Managed Identity / DefaultAzureCredential
AUTH_MODE=identity

# ── Azure OpenAI / AI Foundry ────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_TEMPERATURE=0.3
AZURE_OPENAI_API_KEY=               # Required when AUTH_MODE=key

# ── Azure AI Search ─────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=cpg-knowledge-base
AZURE_SEARCH_SEMANTIC_CONFIG=cpg-semantic-config
AZURE_SEARCH_TOP_K=10
AZURE_SEARCH_API_KEY=               # Required when AUTH_MODE=key

# ── Azure Document Intelligence (for template parsing) ──────────
AZURE_DI_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=                       # Required when AUTH_MODE=key; optional with identity
AZURE_DI_MODEL_ID=prebuilt-layout

# ── Azure Application Insights ──────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
LOG_LEVEL=INFO

# ── Azure Cosmos DB (for session & CPG persistence) ────────────
AZURE_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
AZURE_COSMOS_KEY=                   # Required when AUTH_MODE=key
AZURE_COSMOS_DATABASE=cpg-agent-db
AZURE_COSMOS_CONTAINER=sessions
SESSION_TTL_SECONDS=3600

# ── Application ─────────────────────────────────────────────────
APP_NAME=cpg-multi-agent
ENVIRONMENT=production
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
